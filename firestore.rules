rules_version = '2';
// Server-side enforcement. The app UI mirrors these, but rules are the source
// of truth — a hacked client still can't double-claim, claim while unverified,
// or act while blocked.
service cloud.firestore {
  match /databases/{database}/documents {

    function me() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function verifiedDriver() {
      return request.auth != null
        && me().role == 'DRIVER' && me().verified == true && me().blocked != true;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      // A user edits only their own profile, and can never self-verify or self-unblock.
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid
        && request.resource.data.verified == resource.data.verified
        && request.resource.data.blocked == resource.data.blocked
        && request.resource.data.ratingSum == resource.data.ratingSum
        && request.resource.data.ratingCount == resource.data.ratingCount;
      // verified/blocked/rating flips happen from the admin console / backend only.
    }

    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.uid == request.resource.data.coordinatorId
        || request.auth.uid == resource.data.coordinatorId;

      match /legs/{legId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == request.resource.data.coordinatorId;

        // Claim: OPEN -> CLAIMED by a verified driver, claimedBy must be them.
        // Because the transition is only legal from OPEN, a second concurrent
        // claim (status already CLAIMED) is rejected — first-claim-wins.
        allow update: if verifiedDriver()
          && resource.data.status == 'OPEN'
          && request.resource.data.status == 'CLAIMED'
          && request.resource.data.claimedBy == request.auth.uid;

        // Coordinator drives the rest of the workflow on their own legs.
        allow update: if request.auth.uid == resource.data.coordinatorId;
      }
    }
  }
}
